{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An electrical product for sale.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "price": {
          "type": "number",
          "description": "The regular price of the product."
        },
        "discount": {
          "type": "number",
          "description": "The discount price of the product."
        },
        "delivery": {
          "type": "number",
          "description": "The delivery charge for the product."
        },
        "image": {
          "type": "string",
          "description": "The URL of the product image."
        },
        "category": {
          "type": "string",
          "description": "The category of the product (e.g., fan, switch, LED, cable)."
        }
      },
      "required": ["name", "price", "image", "category"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "A collection of electrical products."
    }
  }
}
